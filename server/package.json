{
  "name": "knot-server",
  "version": "1.0.0",
  "description": "Hono + MongoDB + better-auth backend: auth, RBAC, game scores, leaderboard, user settings, and analytics tracking",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "seed:admin": "tsx src/scripts/seedAdmin.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "better-auth": "^1.2.7",
    "dotenv": "^16.4.5",
    "geoip-lite": "^1.4.10",
    "hono": "^4.6.14",
    "mongodb": "^6.10.0",
    "nanoid": "^5.0.9",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/geoip-lite": "^1.4.4",
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
